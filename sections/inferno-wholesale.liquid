<div class="inferno-site">
 <div class="inferno-announcement">{{ section.settings.announcement_text }}</div>
 <header class="inferno-header">
 <a class="inferno-logo" href="#inferno-top" aria-label="{{ section.settings.logo_word_1 }} {{ section.settings.logo_word_2 }} home">
 <span>{{ section.settings.logo_word_1 }}</span><span>{{ section.settings.logo_word_2 }}</span>
 </a>
 <nav class="inferno-nav" aria-label="Main navigation">
 <a href="#inferno-packs">{{ section.settings.nav_repacks }}</a>
 <a href="#inferno-wholesale">{{ section.settings.nav_wholesale }}</a>
 <a href="#inferno-about">{{ section.settings.nav_about }}</a>
 </nav>
 <a class="inferno-btn" href="#inferno-contact">{{ section.settings.header_button_text }}</a>
 </header>

 <main id="inferno-top">
 <section class="inferno-hero">
 <div class="inferno-hero__copy">
 <p class="inferno-eyebrow">{{ section.settings.hero_eyebrow }}</p>
 <h1 class="inferno-title">{{ section.settings.hero_heading }}<br><em>{{ section.settings.hero_emphasis }}</em></h1>
 <p>{{ section.settings.hero_description }}</p>
 <div class="inferno-actions">
 <a class="inferno-btn" href="#inferno-contact">{{ section.settings.hero_primary_button }}</a>
 <a class="inferno-btn inferno-btn--ghost" href="#inferno-packs">{{ section.settings.hero_secondary_button }}</a>
 </div>
 </div>
 <div class="inferno-hero__art" role="button" tabindex="0" aria-label="{{ section.settings.hero_art_label }}">
 <img class="pack-a" src="{{ 'obsidian.png' | asset_url }}" alt="{{ section.settings.hero_pack_alt_1 }}">
 <img class="pack-b" src="{{ 'infernal.png' | asset_url }}" alt="{{ section.settings.hero_pack_alt_2 }}">
 <img class="pack-c" src="{{ 'hellfire.png' | asset_url }}" alt="{{ section.settings.hero_pack_alt_3 }}">
 </div>
 </section>

 <section id="inferno-packs" class="inferno-section">
 <div class="inferno-section__head">
 <div><p class="inferno-eyebrow">{{ section.settings.lineup_eyebrow }}</p><h2 class="inferno-heading">{{ section.settings.lineup_heading }}</h2></div>
 <p>{{ section.settings.lineup_description }}</p>
 </div>
 <div class="inferno-grid">
 {% for block in section.blocks %}
 {% if block.type == 'pack' %}
 <article class="inferno-card" tabindex="0" aria-label="{{ block.settings.name }}. {{ section.settings.pack_interaction_label }}" {{ block.shopify_attributes }}>
 <div class="inferno-card__image"><img src="{{ block.settings.asset_filename | asset_url }}" alt="{{ block.settings.image_alt }}" loading="lazy"></div>
 <div class="inferno-card__copy">
 <h3>{{ block.settings.name }}</h3>
 <p>{{ block.settings.subtitle }}</p>
 <a class="inferno-btn" href="#inferno-contact">{{ block.settings.button_text }}</a>
 </div>
 </article>
 {% endif %}
 {% endfor %}
 </div>
 </section>

 <section id="inferno-wholesale" class="inferno-wholesale">
 <p class="inferno-eyebrow">{{ section.settings.process_eyebrow }}</p>
 <h2 class="inferno-heading">{{ section.settings.process_heading }}</h2>
 <div class="inferno-steps">
 {% for block in section.blocks %}
 {% if block.type == 'step' %}
 <article class="inferno-step" {{ block.shopify_attributes }}>
 <b>{{ block.settings.number }}</b><h3>{{ block.settings.heading }}</h3><p>{{ block.settings.description }}</p>
 </article>
 {% endif %}
 {% endfor %}
 </div>
 </section>

 <section id="inferno-about" class="inferno-about">
 <div><p class="inferno-eyebrow">{{ section.settings.about_eyebrow }}</p><h2 class="inferno-heading">{{ section.settings.about_heading }}</h2></div>
 <p>{{ section.settings.about_description }}</p>
 </section>

 <section id="inferno-contact" class="inferno-contact">
 <p class="inferno-eyebrow">{{ section.settings.contact_eyebrow }}</p>
 <h2 class="inferno-heading">{{ section.settings.contact_heading }}</h2>
 <p>{{ section.settings.contact_description }}</p>
 {% form 'contact', class: 'inferno-form' %}
 {% if form.posted_successfully? %}<p class="inferno-success">{{ section.settings.success_message }}</p>{% endif %}
 {{ form.errors | default_errors }}
 <div class="inferno-fields">
 <input required type="text" name="contact[name]" placeholder="{{ section.settings.name_placeholder }}">
 <input required type="email" name="contact[email]" placeholder="{{ section.settings.email_placeholder }}">
 <input type="text" name="contact[company]" placeholder="{{ section.settings.company_placeholder }}">
 <input type="tel" name="contact[phone]" placeholder="{{ section.settings.phone_placeholder }}">
 <select name="contact[estimated_volume]">
 <option value="">{{ section.settings.volume_placeholder }}</option>
 <option>{{ section.settings.volume_option_1 }}</option>
 <option>{{ section.settings.volume_option_2 }}</option>
 <option>{{ section.settings.volume_option_3 }}</option>
 <option>{{ section.settings.volume_option_4 }}</option>
 </select>
 <textarea name="contact[body]" placeholder="{{ section.settings.message_placeholder }}"></textarea>
 </div>
 <button class="inferno-btn" type="submit">{{ section.settings.contact_button_text }}</button>
 {% endform %}
 </section>
 </main>
 <footer class="inferno-footer">
 <div class="inferno-logo"><span>{{ section.settings.logo_word_1 }}</span><span>{{ section.settings.logo_word_2 }}</span></div>
 <p>{{ section.settings.footer_text }}</p>
 </footer>
</div>

