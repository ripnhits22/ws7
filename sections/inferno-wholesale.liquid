 {"type":"text","id":"image_alt","label":"Pack image alt text","default":"Inferno repack"}
 ]
 },
 {
 "type":"step",
 "name":"Process step",
 "limit":3,
 "settings":[
 {"type":"text","id":"number","label":"Step number","default":"01"},
 {"type":"text","id":"heading","label":"Step heading","default":"Book a call"},
 {"type":"textarea","id":"description","label":"Step description","default":"Tell us about your shop, channel, event, or resale program."}
